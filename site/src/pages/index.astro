---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import Sidebar from '../components/Sidebar.astro';
import type { EtapaGrupo } from '../lib/tipos';

const lecciones = await getCollection('lecciones');

const porEtapa = new Map<number, { titulo: string; lecciones: typeof lecciones }>();
for (const l of lecciones) {
  const e = l.data.etapa;
  if (!porEtapa.has(e)) {
    porEtapa.set(e, { titulo: l.data.etapaTitulo, lecciones: [] });
  }
  porEtapa.get(e)!.lecciones.push(l);
}

const etapasSidebar: (EtapaGrupo & { activa: boolean })[] = Array.from(porEtapa.entries())
  .sort(([a], [b]) => a - b)
  .map(([num, { titulo, lecciones: lecs }]) => ({
    num,
    titulo,
    activa: false,
    lecciones: lecs
      .sort((a, b) => a.data.leccion - b.data.leccion)
      .map((l) => ({ id: l.id, num: l.data.leccion, titulo: l.data.titulo })),
  }));
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>Curso de Java — Temario</title>
  </head>
  <body class="min-h-screen bg-surface text-text antialiased">
    <Sidebar etapas={etapasSidebar} actual="" total={lecciones.length} />

    <main class="lg:ml-72">
      <div class="mx-auto max-w-3xl px-6 py-12 lg:py-20">
        <header class="mb-12">
          <h1 class="text-4xl font-bold tracking-tight text-text">
            Curso de <span class="text-accent">Java</span>
          </h1>
          <p class="mt-3 text-lg text-text-muted leading-relaxed">
            De cero a Spring Boot + Arquitectura Hexagonal. 20 etapas, 62 lecciones con código real, tests, y despliegue.
          </p>
          <div class="mt-6 flex gap-3">
            <a href="/lecciones/etapa-00-como-funciona-java/leccion-01-que-ocurre-cuando-ejecutas-java" class="rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:opacity-90 transition-opacity">
              Empezar el curso →
            </a>
            <a href="/progreso" class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-text-muted hover:bg-sidebar-hover transition-colors">
              Mi progreso
            </a>
          </div>
        </header>

        <nav class="space-y-10">
          {
            Array.from(porEtapa.entries())
              .sort(([a], [b]) => a - b)
              .map(([num, { titulo, lecciones: lecs }]) => (
                <section>
                  <h2 class="flex items-center gap-3 mb-4">
                    <span class="text-xs font-medium text-text-muted/50 tabular-nums w-6">{String(num).padStart(2, '0')}</span>
                    <span class="text-lg font-semibold text-text">{titulo}</span>
                  </h2>
                  <div class="grid gap-1 sm:grid-cols-2">
                    {lecs
                      .sort((a, b) => a.data.leccion - b.data.leccion)
                      .map((l) => (
                        <a
                          href={`/lecciones/${l.id}`}
                          class="group flex items-start gap-2 rounded-lg border border-border p-3 hover:border-accent/30 hover:bg-accent/[0.02] transition-colors"
                        >
                          <span class="mt-0.5 text-[11px] font-medium text-text-muted/40 tabular-nums">
                            {l.data.leccion}
                          </span>
                          <span class="text-sm text-text-muted group-hover:text-text leading-snug">
                            {l.data.titulo}
                          </span>
                        </a>
                      ))}
                  </div>
                </section>
              ))
          }
        </nav>

        <footer class="mt-16 pt-8 border-t border-border text-sm text-text-muted">
          <p>Construido con Astro, Tailwind CSS, MDX. Código en Java 17 + Spring Boot 3.5.</p>
        </footer>
      </div>
    </main>
  </body>
</html>
