---
import { getCollection, render } from 'astro:content';
import LeccionLayout from '../../layouts/LeccionLayout.astro';
import type { EtapaGrupo } from '../../lib/tipos';

export async function getStaticPaths() {
  const entries = await getCollection('lecciones');

  const porEtapa = new Map<number, typeof entries>();
  for (const e of entries) {
    const etapa = e.data.etapa;
    if (!porEtapa.has(etapa)) porEtapa.set(etapa, []);
    porEtapa.get(etapa)!.push(e);
  }

  const ordenadas: typeof entries = [];
  for (const [, lecs] of Array.from(porEtapa.entries()).sort(([a], [b]) => a - b)) {
    ordenadas.push(...lecs.sort((a, b) => a.data.leccion - b.data.leccion));
  }

  const globalEtapas: EtapaGrupo[] = Array.from(porEtapa.entries())
    .sort(([a], [b]) => a - b)
    .map(([num, lecs]) => ({
      num,
      titulo: lecs[0]!.data.etapaTitulo,
      lecciones: lecs
        .sort((a, b) => a.data.leccion - b.data.leccion)
        .map((l) => ({ id: l.id, num: l.data.leccion, titulo: l.data.titulo })),
    }));

  return ordenadas.map((entry, i) => {
    const anterior = i > 0 ? ordenadas[i - 1] : null;
    const siguiente = i < ordenadas.length - 1 ? ordenadas[i + 1] : null;

    const etapasConActiva = globalEtapas.map((e) => ({
      ...e,
      activa: e.num === entry.data.etapa,
    }));

    return {
      params: { slug: entry.id },
      props: {
        entry,
        anterior: anterior
          ? { titulo: anterior.data.titulo, id: anterior.id }
          : null,
        siguiente: siguiente
          ? { titulo: siguiente.data.titulo, id: siguiente.id }
          : null,
        etapas: etapasConActiva,
        total: entries.length,
      },
    };
  });
}

const { entry, anterior, siguiente, etapas, total } = Astro.props;
const { Content } = await render(entry);
---

<LeccionLayout
  titulo={entry.data.titulo}
  etapaTitulo={entry.data.etapaTitulo}
  etapa={entry.data.etapa}
  leccion={entry.data.leccion}
  slug={entry.id}
  anterior={anterior}
  siguiente={siguiente}
  etapas={etapas}
  total={total}
>
  <Content />
</LeccionLayout>
