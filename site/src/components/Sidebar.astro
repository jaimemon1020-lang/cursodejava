---
import ThemeToggle from './ThemeToggle.astro';

interface LeccionLink {
  id: string;
  num: number;
  titulo: string;
}

interface EtapaGrupo {
  num: number;
  titulo: string;
  lecciones: LeccionLink[];
  activa: boolean;
}

interface Props {
  etapas: EtapaGrupo[];
  actual: string;
  total: number;
}

const { etapas, actual, total } = Astro.props;
---

<nav
  id="sidebar"
  class="fixed inset-y-0 left-0 z-40 flex w-72 -translate-x-full flex-col border-r border-border bg-sidebar transition-transform duration-200 lg:translate-x-0"
>
  <div class="flex items-center gap-2 border-b border-border px-3 py-2.5">
    <a href="/" class="text-lg font-bold tracking-tight text-text">
      curso<span class="text-accent">java</span>
    </a>
    <span class="ml-auto rounded bg-code-bg px-1.5 py-0.5 text-[10px] font-medium text-text-muted">
      v20
    </span>
    <ThemeToggle />
  </div>

  <div class="sidebar-scroll flex-1 overflow-y-auto px-2 py-2">
    {
      etapas.map(({ num, titulo, lecciones, activa }) => (
        <details class="group mb-0.5" open={activa}>
          <summary class="cursor-pointer rounded px-2 py-1.5 text-sm font-medium text-text-muted hover:bg-sidebar-hover hover:text-text select-none">
            <span class="mr-1.5 text-[11px] text-text-muted/50 tabular-nums">{String(num).padStart(2, '0')}</span>
            {titulo}
          </summary>
          <ul class="ml-2 mt-0.5 border-l border-border/60 pl-3">
            {lecciones.map((l) => (
              <li>
                <a
                  href={`/lecciones/${l.id}`}
                  class={`block rounded px-2 py-1 text-[13px] leading-snug transition-colors ${
                    l.id === actual
                      ? 'bg-accent/10 font-medium text-accent'
                      : 'text-text-muted hover:bg-sidebar-hover hover:text-text'
                  }`}
                >
                  {l.num}. {l.titulo}
                </a>
              </li>
            ))}
          </ul>
        </details>
      ))
    }
  </div>

  <div class="border-t border-border px-3 py-2 text-[11px] text-text-muted flex items-center gap-2">
    <a href="/progreso" class="hover:text-text transition-colors">Progreso</a>
    <span class="text-border">|</span>
    <span>{total} lecciones</span>
  </div>
</nav>

<div
  id="sidebar-overlay"
  class="fixed inset-0 z-30 hidden bg-black/30 backdrop-blur-sm lg:hidden"
></div>

<button
  id="sidebar-toggle"
  class="fixed left-3 top-3 z-50 rounded-lg border border-border bg-surface p-2 shadow-sm lg:hidden"
  aria-label="Abrir menú"
>
  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M3 5h14M3 10h14M3 15h14"/>
  </svg>
</button>

<script>
  const sidebar = document.getElementById('sidebar')!;
  const overlay = document.getElementById('sidebar-overlay')!;
  const toggle = document.getElementById('sidebar-toggle')!;

  function open() {
    sidebar.classList.remove('-translate-x-full');
    overlay.classList.remove('hidden');
  }
  function close() {
    sidebar.classList.add('-translate-x-full');
    overlay.classList.add('hidden');
  }

  toggle.addEventListener('click', () => {
    sidebar.classList.contains('-translate-x-full') ? open() : close();
  });
  overlay.addEventListener('click', close);
</script>
