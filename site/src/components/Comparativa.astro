---
interface Props {
  columnas: string[];
  filas: string[][];
}
const { columnas, filas } = Astro.props;
---
<div class="my-5 overflow-x-auto rounded-lg border border-border">
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr class="bg-sidebar">
        {columnas.map((c, i) => (
          <th class={`border-b border-border px-4 py-2.5 text-left font-semibold text-text ${i === 0 ? '' : ''}`}>{c}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {filas.map((fila, ri) => (
        <tr class={ri % 2 === 0 ? 'bg-surface' : 'bg-sidebar/50'}>
          {fila.map((celda, ci) => (
            <td class={`border-b border-border/60 px-4 py-2.5 text-text-muted ${ci === 0 ? 'font-medium text-text' : ''}`}>{celda}</td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>
