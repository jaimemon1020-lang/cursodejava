---
interface Props {
  titulo: string;
}
const { titulo } = Astro.props;
---
<details class="my-5 group rounded-lg border border-border bg-surface">
  <summary class="cursor-pointer px-4 py-3 font-semibold text-text select-none marker:text-text-muted/40 hover:bg-sidebar-hover rounded-lg transition-colors">{titulo}</summary>
  <div class="px-4 pb-4 pt-1 border-t border-border">
    <slot />
  </div>
</details>
